{
  "version": 2,
  "builds": [
    { "src": "admin-dashboard/package.json", "use": "@vercel/next" },
    { "src": "frontend/package.json", "use": "@vercel/next" }
  ],
  "rewrites": [
    { "source": "/admin/:path*", "destination": "/admin-dashboard/:path*" },
    { "source": "/:path*", "destination": "/frontend/:path*" }
  ]
}
